# Telegram
BOT_TOKEN=
ADMIN_IDS=

# Главные админы/ГА. ADMIN_IDS остаётся обязательным, GA_IDS можно использовать как явный список главных.
GA_IDS=

# Direct wallet payments: внешний монитор кошелька должен слать signed webhook на /wallet/webhook.
WALLET_PAYMENT_ENABLED=0
WALLET_PAYMENT_ADDRESS=
WALLET_PAYMENT_CURRENCY=USDT
WALLET_WEBHOOK_SECRET=
MARKETPLACE_ENABLED=1
# Можно указать один ID или несколько через запятую
ADMIN_ALERT_CHAT_ID=
BUG_REPORT_CHAT_IDS=

# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB
ALLOW_SQLITE_ON_RENDER=0

# Crypto Pay / CryptoBot
CRYPTO_PAY_TOKEN=
CRYPTO_PAY_NETWORK=testnet
# Optional. Leave empty to auto-use https://pay.crypt.bot/api on mainnet or testnet-pay on testnet.
CRYPTO_PAY_API_BASE_URL=
CRYPTO_PAY_CHECK_BASE_URL=
CRYPTO_PAY_INVOICE_EXPIRES_SECONDS=3600
CRYPTO_PAY_RECOVERY_INTERVAL_SECONDS=300
CRYPTO_PAY_PENDING_LIMIT=50
CRYPTO_PAY_DELIVERY_STALE_SECONDS=600
STOCK_RESERVATION_TTL_SECONDS=3900

# Proxyline
PROXYLINE_ENABLED=0
PROXYLINE_API_KEY=
PROXYLINE_DEFAULT_COUNTRY=ru
PROXYLINE_DEFAULT_PERIOD=30
PROXYLINE_DEFAULT_COUNT=1
PROXYLINE_DEFAULT_IP_VERSION=4
PROXYLINE_DEFAULT_TYPE=dedicated
PROXYLINE_MTPROXY_MODE=api
PROXYLINE_MTPROXY_API_TYPE=dedicated
PROXYLINE_MTPROXY_TYPE=dedicated
PROXYLINE_COUPON=
PROXYLINE_PRODUCTS_JSON={}
PROXYLINE_COUNTRIES_JSON={}
PROXY_MARKUP_MULTIPLIER=1.77

# Interface and behavior
IGNORE_OTHER_BOTS=1
SERVICE_PAGE_SIZE=8
SUPPLIER_PAGE_SIZE=8
PROBLEM_COOLDOWN_SECONDS=30
POPULAR_SERVICE_THRESHOLD=3
AUTO_DELETE_MESSAGES=0
AUTO_DELETE_DELAY_SECONDS=3
AUTO_DELETE_UNKNOWN_BUYERS=0
IGNORE_NON_BUYERS=0
NOTIFY_UNKNOWN_BUYERS=1
BUTTON_COOLDOWN_SECONDS=2
BUYER_ORDERS_LIMIT=10
SUPPLIER_IMMUNITY_SKIP_AUTODELETE=1

# Optional secondary proxy provider for Standard/Residential tariffs
PROXYS_ENABLED=0
PROXYS_API_KEY=
PROXYS_API_BASE_URL=

# V50 supplier withdrawal settings
WITHDRAWAL_FEE_USD=2.5
WITHDRAW_AUTO_CRYPTOBOT=1
WITHDRAW_PAYOUT_ASSET=USDT


# =========================
# V57 PROXYS.IO native mode
# Standard/default proxies use one common PROXYS.IO API key.
# No base URL is needed unless you want to override the official v2 endpoint.
# =========================
PROXYS_ENABLED=1
PROXYS_PROVIDER_MODE=proxys_io
PROXYS_API_KEY=your_proxys_io_common_api_key
PROXYS_IO_BASE_URL=https://proxys.io/ru/api/v2
PROXYS_IO_SERVICE_ID=1
PROXYS_IO_PROXY_POOL_ID=S1
PROXYS_IO_USE_NEW_USER=0
PROXYS_DEFAULT_PROVIDER_KEY=proxys:default
PROXYS_DEFAULT_SHORT_NAME=default
PROXYS_DEFAULT_COUNTRY=ru
PROXYS_DEFAULT_PERIOD=30
PROXYS_DEFAULT_COUNT=1
PROXYS_DEFAULT_TYPE=standard

# Different base prices are stored in products, not env.
# Use admin UI or SQL to set Premium/Standard/MTProxy prices separately.

# V61 proxy admin/provider settings
PROXY_BALANCE_WARN_USD=10
PROXY_BALANCE_CRITICAL_USD=5
PROXY_BALANCE_CHECK_INTERVAL_SECONDS=1800
# Proxyline: premium + mtproxy
PROXYLINE_ENABLED=1
PROXYLINE_API_KEY=
# Proxys.io: standard + residential
PROXYS_ENABLED=1
PROXYS_PROVIDER_MODE=proxys_io
PROXYS_API_KEY=
PROXYS_IO_BASE_URL=https://proxys.io/ru/api/v2
PROXYS_IO_SERVICE_ID=1
PROXYS_IO_PROXY_POOL_ID=S1
