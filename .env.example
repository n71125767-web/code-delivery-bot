# Telegram
BOT_TOKEN=
ADMIN_IDS=

# Главные админы/ГА. ADMIN_IDS остаётся обязательным, GA_IDS можно использовать как явный список главных.
GA_IDS=

# Direct wallet payments: внешний монитор кошелька должен слать signed webhook на /wallet/webhook.
WALLET_PAYMENT_ENABLED=0
WALLET_PAYMENT_ADDRESS=
WALLET_PAYMENT_CURRENCY=USDT
WALLET_WEBHOOK_SECRET=
MARKETPLACE_ENABLED=1
# Можно указать один ID или несколько через запятую
ADMIN_ALERT_CHAT_ID=
BUG_REPORT_CHAT_IDS=
ADMIN_BUSINESS_CONNECTION_ID=

# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB
ALLOW_SQLITE_ON_RENDER=0

# Crypto Pay / CryptoBot
CRYPTO_PAY_TOKEN=
CRYPTO_PAY_NETWORK=testnet
CRYPTO_PAY_INVOICE_EXPIRES_SECONDS=3600
CRYPTO_PAY_RECOVERY_INTERVAL_SECONDS=300
CRYPTO_PAY_PENDING_LIMIT=50
CRYPTO_PAY_DELIVERY_STALE_SECONDS=600
STOCK_RESERVATION_TTL_SECONDS=3900

# Proxyline
PROXYLINE_ENABLED=0
PROXYLINE_API_KEY=
PROXYLINE_DEFAULT_COUNTRY=ru
PROXYLINE_DEFAULT_PERIOD=30
PROXYLINE_DEFAULT_COUNT=1
PROXYLINE_DEFAULT_IP_VERSION=4
PROXYLINE_DEFAULT_TYPE=dedicated
PROXYLINE_COUPON=
PROXYLINE_PRODUCTS_JSON={}
PROXYLINE_COUNTRIES_JSON={}

# Interface and behavior
IGNORE_OTHER_BOTS=1
SERVICE_PAGE_SIZE=8
SUPPLIER_PAGE_SIZE=8
PROBLEM_COOLDOWN_SECONDS=30
POPULAR_SERVICE_THRESHOLD=3
AUTO_DELETE_MESSAGES=0
AUTO_DELETE_DELAY_SECONDS=3
AUTO_DELETE_UNKNOWN_BUYERS=0
IGNORE_NON_BUYERS=0
NOTIFY_UNKNOWN_BUYERS=1
BUTTON_COOLDOWN_SECONDS=2
BUYER_ORDERS_LIMIT=10
SUPPLIER_IMMUNITY_SKIP_AUTODELETE=1
